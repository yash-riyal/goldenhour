PORT=3000
JWT_SECRET=replace-with-a-long-random-secret-for-production
NODE_ENV=production
UPLOAD_DIR=server/uploads

# ─── MySQL connection ─────────────────────────────────────────────
# Production: paste your DATABASE_URL from Aiven / Railway / PlanetScale.
# Format: mysql://user:password@host:3306/dbname?ssl-mode=REQUIRED
DATABASE_URL=

# Local development: leave DATABASE_URL blank and use these instead.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=goldenhour

# ─── AI vision (optional) ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Maps (optional, for accurate road routes) ────────────────────
# Free key from https://www.geoapify.com/ (no credit card)
GEOAPIFY_API_KEY=
